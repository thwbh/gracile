<ul>
  <li>{= a + b * 2}</li>
  <li>{= greeting ?? "Hello, stranger!"}</li>
  <li>{= first + " " + last}</li>
  <li>{= x > 0 ? "positive" : "non-positive"}</li>
{#if "admin" in roles}
  <li>Has admin role.</li>
{/if}
{#if age is even}
  <li>Even age.</li>
{:else}
  <li>Odd age.</li>
{/if}
{#if bio is empty}
  <li>No bio provided.</li>
{/if}
</ul>
